<div class="min-h-screen flex flex-col bg-slate-100">
  <header class="w-full bg-white border-b">
    <div class="max-w-5xl mx-auto h-16 px-4 flex items-center justify-between">
      <%= link_to root_path, class: "group flex items-center gap-2 transition-transform hover:scale-105" do %>
        <span class="text-xl font-black bg-linear-to-r from-slate-900 via-sky-600 to-emerald-600 bg-clip-text text-transparent">
          Darts Events
        </span>
      <% end %>

      <% if user_signed_in? %>
        <%= link_to root_path_path,
              class: "inline-flex items-center gap-1.5 rounded-lg border-2 border-slate-300 px-4 py-2 text-sm font-bold text-slate-700 hover:border-sky-400 hover:bg-sky-50 transition-all" do %>
          <span>マイページ</span>
        <% end %>
      <% else %>
        <%= link_to new_user_session_path,
              class: "inline-flex items-center gap-1.5 rounded-lg border-2 border-slate-300 px-4 py-2 text-sm font-bold text-slate-700 hover:border-sky-400 hover:bg-sky-50 transition-all" do %>
          <span>ログイン</span>
        <% end %>
      <% end %>
    </div>
  </header>

  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-4 py-10">
      <h1 class="text-center text-3xl font-bold mb-2">新規登録</h1>
      <p class="text-center text-slate-500 mb-8">
        基本情報を入力してアカウントを作成してください
      </p>

      <div class="bg-white rounded-2xl shadow-md p-6 sm:p-8">
        <h2 class="text-lg font-semibold mb-1">
          ユーザー登録
        </h2>
        <p class="text-sm text-slate-500 mb-6">
          登録後に店舗オーナー・プロプレイヤーの申請ができます。
        </p>

        <% if resource.errors.any? %>
          <div class="mb-4 rounded-md bg-red-50 border border-red-200 p-4 text-sm text-red-700">
            <p class="font-semibold mb-1">入力内容にエラーがあります。</p>
            <ul class="list-disc list-inside">
              <% resource.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <div class="space-y-4">
            <div>
              <%= f.label :name, "ユーザー名", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <%= f.text_field :name, autofocus: true, placeholder: "ユーザー名", 
              class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-sky-500" %>
            </div>

            <div>
              <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <%= f.email_field :email, autocomplete: "email", placeholder: "email",
              class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-sky-500" %>
            </div>

            <div>
              <%= f.label :password, "パスワード", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <% if @minimum_password_length %>
                <p class="text-xs text-slate-500 mb-1">※ <%= @minimum_password_length %>文字以上</p>
              <% end %>
              <%= f.password_field :password,
                    autocomplete: "new-password",
                    placeholder: "パスワード",
                    class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-sky-500" %>
            </div>

            <div>
              <%= f.label :password_confirmation, "パスワード確認", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <%= f.password_field :password_confirmation,
                    autocomplete: "new-password",
                    placeholder: "パスワード確認",
                    class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-sky-500" %>
            </div>

            <div class="pt-2">
              <%= f.submit "アカウントを作成",
                    class: "w-full inline-flex justify-center items-center rounded-md bg-black px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2" %>
            </div>
          </div>
        <% end %>

        <div class="my-3 flex items-center gap-3">
          <div class="h-px flex-1 bg-slate-200"></div>
          <span class="text-xs font-medium text-slate-400">または</span>
          <div class="h-px flex-1 bg-slate-200"></div>
        </div>

        <div class="mt-2 text-center text-sm text-slate-600 space-y-1">
          <div>
            <%= button_to user_google_oauth2_omniauth_authorize_path,
                  method: :post,
                  data: { turbo: false },
                  form: { class: "w-full" },
                  class: "w-full inline-flex items-center justify-center gap-2 rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 hover:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2 transition" do %>
              <svg class="h-4 w-4" viewBox="0 0 48 48" aria-hidden="true">
                <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303C33.654 32.657 29.195 36 24 36c-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.27 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/>
                <path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.27 4 24 4c-7.682 0-14.347 4.337-17.694 10.691z"/>
                <path fill="#4CAF50" d="M24 44c5.17 0 9.86-1.977 13.409-5.193l-6.19-5.238C29.145 35.091 26.715 36 24 36c-5.175 0-9.624-3.332-11.283-7.946l-6.522 5.025C9.5 39.556 16.227 44 24 44z"/>
                <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.046 12.046 0 0 1-4.084 5.569l.003-.002 6.19 5.238C37.01 39.171 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/>
              </svg>
              <span>Googleで登録 / ログイン</span>
            <% end %>
          </div>
          <p>
            既にアカウントをお持ちですか？
            <%= link_to "ログイン", new_session_path(resource_name),
                  class: "text-sky-600 font-semibold hover:underline" %>
          </p>
        </div>
      </div>
    </div>
  </main>

  <footer class="bg-white border-t">
    <div class="max-w-6xl mx-auto px-4 py-6 text-xs sm:text-sm text-slate-600">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <span class="font-semibold tracking-wide text-slate-700">
            Darts Events
          </span>
        <% end %>  

        <nav class="flex flex-wrap gap-6">
          <%= link_to "利用規約", terms_path, class: "hover:underline hover:text-slate-800" %>
          <%= link_to "プライバシーポリシー", privacy_path, class: "hover:underline hover:text-slate-800" %>
          <%= link_to "お問い合わせ",
              "https://docs.google.com/forms/d/e/1FAIpQLSdF6YwUpjdKeqf77hfXWhVc4AUY8pCgmrFnL3NF2awASJiRrw/viewform?usp=header",
              target: "_blank",
              rel: "noopener",
              class: "hover:underline hover:text-slate-800" %>
        </nav>
      </div>

      <div class="mt-6 text-[11px] text-slate-400 text-center sm:text-left">
        &copy; <%= Time.current.year %> Darts Events. All rights reserved.
      </div>
    </div>
  </footer>
</div>
